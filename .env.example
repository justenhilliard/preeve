# Full spec + explanations: docs/TECH_STACK.md -> Environment Variables
# frontend vars go in frontend/.env.local, backend vars go in backend/.env
# Never commit the actual files — both are already in .gitignore.

# --- frontend/.env.local ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- backend/.env ---
DATABASE_URL=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=
R2_PRESIGNED_URL_EXPIRY_SECONDS=3600

REPLICATE_API_TOKEN=

# Vision attribute extraction (structured garment perception only,
# server-side only, never expose to the frontend).
OPENAI_API_KEY=

MAX_UPLOAD_FILE_SIZE_MB=5
IMAGE_MAX_DIMENSION_PX=1600
IMAGE_JPEG_QUALITY=80

CORS_ALLOWED_ORIGINS=http://localhost:3000
