# Copy this file to .env.local (frontend) / .env (backend) and fill in real values.
# Never commit the actual .env files — they're already in .gitignore.

# Database
DATABASE_URL=

# Auth provider (e.g., Clerk, Supabase Auth, Auth.js)
AUTH_PROVIDER_PUBLIC_KEY=
AUTH_PROVIDER_SECRET_KEY=

# CV/ML inference (hosted CLIP endpoint)
CLIP_API_KEY=
CLIP_API_ENDPOINT=

# Object storage (S3-compatible: Cloudflare R2 or AWS S3)
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET_NAME=
STORAGE_ENDPOINT=
